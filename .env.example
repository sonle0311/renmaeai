# ============================================
# RenmaeAI v2 — Environment Variables
# Copy file này thành .env và điền giá trị thật
# ============================================

# === Database (PostgreSQL) ===
DATABASE_URL="postgresql://renmaeai:renmaeai_dev_2026@localhost:5433/renmaeai?schema=public"

# === Redis (BullMQ Queue) ===
REDIS_URL="redis://localhost:6379"

# === NextAuth.js ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# === Google OAuth (NextAuth Provider) ===
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === Polar.sh (Payment) ===
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""

# === NestJS API ===
API_PORT=4000
JWT_SECRET="your-jwt-secret-change-this-in-production"

# === Webhook Security ===
GLABS_WEBHOOK_SECRET="your-webhook-secret"

# === App Config ===
NODE_ENV="development"
