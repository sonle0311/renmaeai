# ============================================
# RenmaeAI v2 — Environment Variables
# Copy file này thành .env và điền giá trị thật
# ============================================

# === Database (PostgreSQL) ===
DATABASE_URL="postgresql://renmaeai:renmaeai_dev_2026@localhost:5433/renmaeai?schema=public"

# === Redis (BullMQ Queue) ===
REDIS_URL="redis://localhost:6379"

# === NextAuth.js (v5 / Auth.js) ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"
AUTH_SECRET="your-secret-key-change-this-in-production"
AUTH_TRUST_HOST=true

# === Google OAuth (NextAuth Provider) ===
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === Polar.sh (Payment) ===
# true = sandbox API (test, không charge thật), false = production
POLAR_SANDBOX=true
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""
# Product IDs — sandbox (copy từ sandbox.polar.sh)
POLAR_PRODUCT_ID_PRO_SANDBOX=""
POLAR_PRODUCT_ID_BUSINESS_SANDBOX=""
# Product IDs — production (copy từ polar.sh khi go-live)
POLAR_PRODUCT_ID_PRO=""
POLAR_PRODUCT_ID_BUSINESS=""

# === NestJS API ===
API_PORT=4000
JWT_SECRET="your-jwt-secret-change-this-in-production"

# === Webhook Security ===
GLABS_WEBHOOK_SECRET="your-webhook-secret"

# === App Config ===
NODE_ENV="development"

# === AI Fallback Keys (Server-side, used when user keys fail) ===
GEMINI_API_KEY=""
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
