{
    "meta": {
        "schema_version": "1.1.0",
        "awf_version": "4.0.2",
        "last_updated": "2026-03-09T11:03:00+07:00"
    },
    "project": {
        "name": "RenmaeAI v2",
        "type": "SaaS Web App (AI Video Production)",
        "status": "pipeline_overhaul_complete",
        "description": "Platform sản xuất video AI tự động. User nhập script/YouTube URL → hệ thống gen script, voice, visual → mux video. BYOK model (G-Labs, ElevenLabs). Client-side FFmpeg assembly.",
        "repo": "d:/projects/renmaeai"
    },
    "tech_stack": {
        "monorepo": "Turborepo (npm workspaces)",
        "frontend": {
            "framework": "Next.js 15 (App Router, TypeScript)",
            "auth": "NextAuth.js v5 (Auth.js) + PrismaAdapter + Google OAuth",
            "ui": "TailwindCSS + custom components (Shadcn-style dark mode)",
            "realtime": "socket.io-client",
            "drag_drop": "@dnd-kit/core + @dnd-kit/sortable",
            "video_processing": "@ffmpeg/ffmpeg + @ffmpeg/util (WebAssembly, client-side)",
            "packaging": "JSZip + file-saver"
        },
        "backend": {
            "framework": "NestJS 11 (TypeScript, strict mode)",
            "queue": "BullMQ (Redis-backed)",
            "auth": "Custom JwtAuthGuard (verify via NextAuth session endpoint)",
            "realtime": "@nestjs/platform-socket.io + @nestjs/websockets",
            "rate_limiting": "@nestjs/throttler (100 req/60s global)",
            "config": "@nestjs/config (global)"
        },
        "database": {
            "primary": "PostgreSQL 15 (Docker, port 5433 host → 5432 container)",
            "cache_queue": "Redis 7 (Docker, port 6379)",
            "orm": "Prisma v6.19.2 (@renmaeai/database workspace package)"
        },
        "deployment": {
            "containerization": "Docker multi-stage (node:20-alpine)",
            "orchestration": "docker-compose.prod.yml (5 services)",
            "reverse_proxy": "Caddy 2 (auto-HTTPS Let's Encrypt)",
            "target": "Self-hosted VPS (Ubuntu)"
        }
    },
    "database_schema": {
        "summary": "8 models: User (auth+quota+BYOK), Account/Session/VerificationToken (NextAuth), Project (nhóm video), Production (1 video job), PipelineCheckpoint (13 bước xử lý), AuditLog (ghi lại mọi hành động)",
        "tables": [
            {
                "name": "User",
                "key_fields": [
                    "email",
                    "role",
                    "subscriptionTier",
                    "aiSettings(JSON)",
                    "usedVideoCount",
                    "monthlyVideoQuota",
                    "usedMinuteCount",
                    "monthlyMinuteQuota",
                    "maxConcurrentSlots",
                    "polarCustomerId"
                ]
            },
            {
                "name": "Account",
                "purpose": "NextAuth OAuth provider accounts"
            },
            {
                "name": "Session",
                "purpose": "NextAuth database sessions"
            },
            {
                "name": "VerificationToken",
                "purpose": "NextAuth email verification"
            },
            {
                "name": "Project",
                "key_fields": [
                    "userId",
                    "name",
                    "globalSettings(JSON)"
                ]
            },
            {
                "name": "Production",
                "key_fields": [
                    "projectId",
                    "title",
                    "status(DRAFT|QUEUED|PROCESSING|COMPLETED|FAILED)",
                    "currentStep",
                    "inputScript",
                    "youtubeUrl",
                    "language",
                    "mediaGeneration",
                    "estimatedMinutes"
                ]
            },
            {
                "name": "PipelineCheckpoint",
                "key_fields": [
                    "productionId",
                    "stepNumber(1-13)",
                    "stepName",
                    "status",
                    "outputData(JSON)"
                ]
            },
            {
                "name": "AuditLog",
                "key_fields": [
                    "userId",
                    "action",
                    "description",
                    "metadata(JSON)"
                ]
            }
        ],
        "relationships": "User→Projects (1:N), Project→Productions (1:N), Production→PipelineCheckpoints (1:N), User→AuditLogs (1:N)"
    },
    "api_endpoints": [
        {
            "method": "GET",
            "path": "/api/v1/projects",
            "auth": true,
            "explained": "Danh sách dự án của user"
        },
        {
            "method": "POST",
            "path": "/api/v1/projects",
            "auth": true,
            "explained": "Tạo dự án mới"
        },
        {
            "method": "PUT",
            "path": "/api/v1/projects/:id",
            "auth": true,
            "explained": "Cập nhật dự án"
        },
        {
            "method": "DELETE",
            "path": "/api/v1/projects/:id",
            "auth": true,
            "explained": "Xoá dự án"
        },
        {
            "method": "GET",
            "path": "/api/v1/projects/:projectId/productions",
            "auth": true,
            "explained": "Danh sách video trong dự án"
        },
        {
            "method": "GET",
            "path": "/api/v1/productions/:id",
            "auth": true,
            "explained": "Chi tiết video + checkpoints"
        },
        {
            "method": "POST",
            "path": "/api/v1/productions",
            "auth": true,
            "explained": "Tạo video mới → trừ quota → đẩy BullMQ (trả 202)"
        },
        {
            "method": "POST",
            "path": "/api/v1/webhooks/glabs",
            "auth": "webhook_secret",
            "explained": "Callback từ G-Labs khi gen xong → cập nhật checkpoint + emit Socket.IO"
        },
        {
            "method": "POST",
            "path": "/api/v1/webhooks/polar",
            "auth": "signature",
            "explained": "Subscription events từ Polar.sh → upgrade/downgrade tier"
        }
    ],
    "socket_events": [
        {
            "event": "pipeline:step:started",
            "direction": "server→client",
            "data": "productionId, stepNumber, stepName"
        },
        {
            "event": "pipeline:step:completed",
            "direction": "server→client",
            "data": "productionId, stepNumber"
        },
        {
            "event": "pipeline:step:failed",
            "direction": "server→client",
            "data": "productionId, error"
        },
        {
            "event": "pipeline:completed",
            "direction": "server→client",
            "data": "productionId"
        },
        {
            "event": "quota:updated",
            "direction": "server→client",
            "data": "productionId"
        }
    ],
    "pipeline_steps": [
        {
            "step": 1,
            "name": "YouTube Extract",
            "type": "local",
            "phase": "A-Input"
        },
        {
            "step": 2,
            "name": "Style Analysis",
            "type": "local",
            "phase": "A-Input"
        },
        {
            "step": 3,
            "name": "Script Generation",
            "type": "AI (Gemini)",
            "phase": "A-Input"
        },
        {
            "step": 4,
            "name": "Scene Splitting",
            "type": "local (algorithm)",
            "phase": "A-Input"
        },
        {
            "step": 5,
            "name": "AI Director (Concept Analysis)",
            "type": "AI (Gemini), non-blocking",
            "phase": "A-Input"
        },
        {
            "step": 6,
            "name": "Voice TTS",
            "type": "external (Edge-TTS), builds 8s video segments",
            "phase": "B-Audio"
        },
        {
            "step": 7,
            "name": "Video Direction (6 Pillars)",
            "type": "AI (Gemini), batched",
            "phase": "C-Visual"
        },
        {
            "step": 8,
            "name": "VEO Prompts (4 modes: T2V/I2V/F&LF/SB)",
            "type": "AI (Gemini)",
            "phase": "C-Visual"
        },
        {
            "step": 9,
            "name": "Entity Extraction",
            "type": "AI (Gemini)",
            "phase": "C-Visual"
        },
        {
            "step": 10,
            "name": "Reference Image Prompts",
            "type": "AI (Gemini)",
            "phase": "C-Visual"
        },
        {
            "step": 11,
            "name": "Scene Builder Prompts",
            "type": "AI (Gemini), batched",
            "phase": "C-Visual"
        },
        {
            "step": 12,
            "name": "Metadata & SEO",
            "type": "placeholder",
            "phase": "D-Finalize"
        },
        {
            "step": 13,
            "name": "Finalize",
            "type": "local",
            "phase": "D-Finalize"
        }
    ],
    "business_rules": [
        "BYOK model: User nhập token G-Labs/ElevenLabs riêng, lưu JSON trong aiSettings",
        "Virtual Quota: FREE=1 video/5 phút/tháng, PRO=60/600, BUSINESS=250/5000",
        "Concurrent Slots: FREE=1, PRO=3, BUSINESS=10",
        "Trừ video quota khi tạo Production (trước khi xử lý), trừ minute quota khi hoàn tất",
        "Single-session login enforcement (qua NextAuth database sessions)",
        "Admin RBAC: chỉ role=ADMIN mới truy cập /admin/*"
    ],
