# ============================================
# RenmaeAI v2 - Production Environment Variables
# ============================================
# Copy file này thành .env trên VPS trước khi chạy docker-compose.prod.yml
# KHÔNG ĐƯỢC push file .env lên Git!

# === Database ===
POSTGRES_USER=renmaeai
POSTGRES_PASSWORD=THAY_PASSWORD_THAT_MANH
POSTGRES_DB=renmaeai

# === Auth (NextAuth.js) ===
NEXTAUTH_URL=https://app.renmae.ai
NEXTAUTH_SECRET=GENERATE_BANG_openssl_rand_base64_32
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# === API ===
JWT_SECRET=GENERATE_BANG_openssl_rand_base64_32

# === Webhooks ===
GLABS_WEBHOOK_SECRET=RANDOM_SECRET_CHO_WEBHOOK

# === Public URLs ===
NEXT_PUBLIC_API_URL=https://api.renmae.ai

# === Payments (Polar.sh) ===
POLAR_ACCESS_TOKEN=polar_xxx
POLAR_WEBHOOK_SECRET=whsec_xxx
